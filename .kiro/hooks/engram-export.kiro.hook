{
  "enabled": true,
  "name": "Exportar Engram",
  "description": "Exporta las memorias de Engram a .kiro/shared-knowledge/ para compartir con el equipo via Git.",
  "version": "1.0.0",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/engram-sync.sh export"
  }
}
