{
  "enabled": true,
  "name": "Importar Engram",
  "description": "Importa memorias compartidas del equipo desde .kiro/shared-knowledge/ a tu Engram local.",
  "version": "1.0.0",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "bash .kiro/scripts/engram-sync.sh import"
  }
}
