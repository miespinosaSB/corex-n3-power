{
  "enabled": true,
  "name": "Validate Sonar Configuration",
  "description": "Verifica que sonar-project.properties no contenga placeholders sin reemplazar después de ser editado.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/sonar-project.properties"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "El archivo sonar-project.properties fue modificado. Verifica que NO contenga placeholders sin reemplazar. Busca las siguientes cadenas que NO deberían estar presentes en el archivo final:\n\n- {nombre-ms}\n- {nombre-repo}\n- {NombreMs}\n- {dominio}\n\nSi encuentras algún placeholder sin reemplazar, reemplázalo con el valor correcto basándote en el contexto del proyecto (nombre del microservicio, clase Application, etc.)."
  }
}
