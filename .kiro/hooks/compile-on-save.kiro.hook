{
  "enabled": true,
  "name": "Compile on Save",
  "description": "Ejecuta compilación incremental de Gradle cuando se guarda un archivo Java para detectar errores de compilación temprano.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.java"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "./gradlew classes testClasses -q --no-daemon 2>&1 | tail -20"
  }
}
