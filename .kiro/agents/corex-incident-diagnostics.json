{
  "name": "corex-incident-diagnostics",
  "description": "Diagnóstico Profundo de Incidentes Corex — Solo diagnóstico, apalancado en el power corex-n3. Uso: 'Diagnostica el caso MDSB-XXXXX'",
  "prompt": "file://.kiro/agents/corex-incident-diagnostics.prompt.md",
  "tools": ["fs_read", "execute_bash", "grep", "glob"],
  "allowedTools": [
    "fs_read", "grep", "glob",
    "@mcp-atlassian",
    "@oracle-readonly",
    "@oracle-stage"
  ],
  "resources": [
    "file://powers/corex-n3/POWER.md",
    "skill://powers/corex-n3/steering/atencion-incidente-autonomo.md",
    "skill://powers/corex-n3/steering/base-conocimiento.md",
    "skill://powers/corex-n3/steering/oracle-consultas.md",
    "skill://powers/corex-n3/steering/auto-mejora.md",
    "skill://powers/corex-n3/steering/analisis-impacto.md",
    "skill://powers/corex-n3/steering/oracle-conventions.md"
  ],
  "mcpServers": {
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "UV_NATIVE_TLS": "true",
        "JIRA_URL": "https://jirasegurosbolivar.atlassian.net",
        "JIRA_USERNAME": "${env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "${env:JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "https://jirasegurosbolivar.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "${env:JIRA_USERNAME}",
        "CONFLUENCE_API_TOKEN": "${env:JIRA_API_TOKEN}"
      }
    },
    "oracle-readonly": {
      "command": "sh",
      "args": ["-c", "set -a; [ -f \"$HOME/.kiro/settings/.env\" ] && . \"$HOME/.kiro/settings/.env\"; set +a; exec uv run \"$HOME/.kiro/powers/installed/corex-n3/server.py\""],
      "env": {
        "UV_NATIVE_TLS": "true",
        "ORACLE_HOST": "10.1.2.76",
        "ORACLE_PORT": "1521",
        "ORACLE_SID": "tron"
      }
    },
    "oracle-stage": {
      "command": "sh",
      "args": ["-c", "set -a; [ -f \"$HOME/.kiro/settings/.env\" ] && . \"$HOME/.kiro/settings/.env\"; set +a; exec uv run \"$HOME/.kiro/powers/installed/corex-n3/server.py\""],
      "env": {
        "UV_NATIVE_TLS": "true",
        "ORACLE_HOST": "10.7.2.14",
        "ORACLE_PORT": "1521",
        "ORACLE_SID": "tron",
        "ORACLE_USER": "${env:ORACLE_STAGE_USER}",
        "ORACLE_PASSWORD": "${env:ORACLE_STAGE_PASSWORD}"
      }
    }
  },
  "keyboardShortcut": "ctrl+shift+d",
  "welcomeMessage": "🔍 Agente de Diagnóstico Corex listo. Dime: 'Diagnostica el caso MDSB-XXXXX'\nNOTA: Solo diagnóstico. Para ciclo completo usa el power corex-n3 con 'atiende el caso MDSB-XXXXX'."
}
