{
  "name": "corex-implementation",
  "description": "Implementación de cambios Corex — Crea ramas, aplica cambios PL/SQL puntuales, genera PRs. Uso: 'Implementa el fix para GD986-XXXX'",
  "prompt": "file://.kiro/agents/corex-implementation.prompt.md",
  "tools": ["fs_read", "fs_write", "execute_bash", "grep", "glob", "str_replace"],
  "allowedTools": [
    "fs_read", "fs_write", "str_replace", "grep", "glob", "execute_bash",
    "@mcp-atlassian",
    "@oracle-readonly"
  ],
  "resources": [
    "file://powers/corex-n3/POWER.md",
    "skill://powers/corex-n3/steering/workflow-git.md",
    "skill://powers/corex-n3/steering/oracle-conventions.md",
    "skill://powers/corex-n3/steering/analisis-impacto.md",
    "skill://powers/corex-n3/steering/deteccion-colisiones.md",
    "skill://powers/corex-n3/steering/pull-request-template.md",
    "skill://powers/corex-n3/steering/sinonimos-grants-nuevos-objetos.md"
  ],
  "mcpServers": {
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "UV_NATIVE_TLS": "true",
        "JIRA_URL": "https://jirasegurosbolivar.atlassian.net",
        "JIRA_USERNAME": "${env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "${env:JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "https://jirasegurosbolivar.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "${env:JIRA_USERNAME}",
        "CONFLUENCE_API_TOKEN": "${env:JIRA_API_TOKEN}"
      }
    },
    "oracle-readonly": {
      "command": "sh",
      "args": ["-c", "set -a; [ -f \"$HOME/.kiro/settings/.env\" ] && . \"$HOME/.kiro/settings/.env\"; set +a; exec uv run \"$HOME/.kiro/powers/installed/corex-n3/server.py\""],
      "env": {
        "UV_NATIVE_TLS": "true",
        "ORACLE_HOST": "10.1.2.76",
        "ORACLE_PORT": "1521",
        "ORACLE_SID": "tron"
      }
    }
  },
  "keyboardShortcut": "ctrl+shift+i",
  "welcomeMessage": "🛠️ Agente de Implementación Corex listo.\nComandos:\n- 'Implementa el fix para GD986-XXXX'\n- 'Crea la rama para GD986-XXXX'\n- 'Genera el PR para GD986-XXXX'\nNOTA: Solo cambios puntuales. NUNCA reemplaza archivos completos."
}
